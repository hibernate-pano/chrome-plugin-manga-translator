# Server configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
SERVER_AUTH_TOKEN=your-secret-token-here
CACHE_DIR=./data/cache
DB_PATH=./data/cache/translator.sqlite3

# Translation provider order (comma-separated: baidu,deepl,google)
MT_PROVIDER_ORDER=baidu,deepl,google

# DeepL API (optional)
DEEPL_API_KEY=
DEEPL_BASE_URL=https://api-free.deepl.com/v2/translate

# Google Translate API (optional)
GOOGLE_TRANSLATE_API_KEY=
GOOGLE_TRANSLATE_BASE_URL=https://translation.googleapis.com/language/translate/v2

# Baidu Translate API (optional)
BAIDU_APP_ID=
BAIDU_SECRET_KEY=
BAIDU_BASE_URL=https://fanyi-api.baidu.com/api/trans/vip/translate

# Vision LLM (OpenAI-compatible API)
VLM_PROVIDER=openai-compatible
VLM_BASE_URL=https://api.siliconflow.cn/v1
VLM_API_KEY=
VLM_MODEL=Qwen/Qwen2.5-VL-32B-Instruct

# Text LLM for context-aware translation
TEXT_LLM_BASE_URL=https://api.siliconflow.cn/v1
TEXT_LLM_API_KEY=
TEXT_LLM_MODEL=Qwen/Qwen2.5-32B-Instruct

# OCR settings
OCR_LANGUAGES=japan,korean,en
OCR_LOW_CONFIDENCE_THRESHOLD=0.72
MAX_FALLBACK_REGION_RATIO=0.35
